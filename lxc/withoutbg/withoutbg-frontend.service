[Unit]
Description=withoutBG Frontend
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/withoutbg/apps/web/frontend

# Pointing directly to the permanent bin directory
ExecStart=/home/nicholas/.local/share/fnm/node-versions/v24.15.0/installation/bin/npx serve -s dist -l 3000

Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
